rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== USERS: each user reads/writes only their own profile =====
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;

      // Device registry for the 3-device cap
      match /devices/{deviceId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ===== PRO ACTIVATION CLAIMS (UTR submissions) =====
    match /claims/{claimId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // ===== PAYMENTS log (server/admin managed) =====
    match /payments/{paymentId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid || isAdmin();
      allow write: if isAdmin();
    }

    // ===== ADMINS allowlist =====
    match /admins/{uid} {
      allow read: if request.auth != null;
      allow write: if false; // manage manually in console
    }

    // ===== SYNC CIRCLE / PULSE: anonymous intent counters, public read/increment =====
    match /pulse/{docId} {
      allow read: if true;
      allow write: if request.auth != null; // increment-only pattern enforced client-side
    }

    // ===== FEATURE REQUESTS =====
    match /requests/{reqId} {
      allow create: if request.auth != null;
      allow read: if isAdmin();
    }

    // ===== DAILY STATS (funnel tracking) =====
    match /stats/{day} {
      allow read: if isAdmin();
      allow write: if true; // increment-only counters from the client funnel tracker
    }

    // ===== RATINGS & TESTIMONIALS: public read, one doc per user (doc id = uid) =====
    match /ratings/{uid} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.stars is int
        && request.resource.data.stars >= 1
        && request.resource.data.stars <= 5
        && (!('text' in request.resource.data) || request.resource.data.text.size() <= 200);
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // ===== TRIP SQUADS: safe, anchored posts — public read, owner-only edit/delete =====
    match /squads/{squadId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.note.size() <= 140
        && (!('contact' in request.resource.data) || request.resource.data.contact.size() <= 80);
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
      allow update: if false; // posts are immutable once created — delete + repost instead
    }

    // ===== REPORTS (moderation flags): write-only from clients, admin-only read =====
    match /reports/{reportId} {
      allow create: if request.auth != null || true; // allow anonymous reports too
      allow read, update, delete: if isAdmin();
    }

    // ===== Helper =====
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
  }
}
